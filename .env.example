# Optional modules to install on first boot, comma-separated (telemetry, updater).
MTP_MODULES=telemetry,updater

# Absolute host path mounted at /var/storage. Required.
MTP_TON_STORAGE_PATH=

# Total disk space dedicated to providing, in GB. Required - must fit free disk.
MTP_TON_STORAGE_PROVIDER_SPACE_GB=

# Storage rate in TON per 200 GB per month. Required.
MTP_TON_STORAGE_PROVIDER_STORAGE_COST=

# UI language: en, ru, or zh.
LANG=en
